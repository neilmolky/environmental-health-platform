FROM ghcr.io/astral-sh/uv:0.11.21-python3.13-trixie
WORKDIR /workspace

# 1. add the location of the venv to the path
ENV PATH="/workspace/.venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1

# 2. Add a dev user matching your host machine mappings (UID/GID 1000)
RUN groupadd --gid 1000 dev \
    && useradd --uid 1000 --gid 1000 -m dev \
    && chown -R dev:dev /workspace

# 3. Safely drop privileges to the dev user for all subsequent build steps
USER dev

# 4. Copy the global workspace configurations (COPY always runs as ROOT)
COPY --chown=dev:dev pyproject.toml uv.lock ./
COPY --chown=dev:dev mock/pyproject.toml /workspace/mock/
COPY --chown=dev:dev utils/pyproject.toml /workspace/utils/

# 5. Sync only required dependencies using a user-owned host build cache grant dev full access to the cache mount.
RUN --mount=type=cache,target=/home/dev/.cache/uv,uid=1000 \
    uv sync --no-install-workspace --all-packages

# 6. Copy source code into the active image workspace (COPY always runs as ROOT)
COPY --chown=dev:dev mock/ /workspace/mock/
COPY --chown=dev:dev utils/ /workspace/utils/

# 7. sync all workspace dependencies into the active image workspace
RUN --mount=type=cache,target=/home/dev/.cache/uv,uid=1000 \
    uv sync --all-packages

# 8. Expose the service port
EXPOSE 8001

# Generic fallback command. Overridden dynamically by orchestration
CMD ["python3"]
