{
  "name": "Environmental Health Platform (Workspace)",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "backend",
  "workspaceFolder": "/workspace",
  "runServices": [
    "backend",
    "minio",
    "azurite"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "marimo-team.marimo-vscode",
        "astral-sh.ty"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "backend",
          "api",
          "frontend"
        ],
        
        "python.languageServer": "None",

        // FORCE RUFF TO ACT AS THE FORMATTER IN THE UI
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        }
      }
    },
    "remoteUser": "root",
    "postCreateCommand": "uv sync --frozen --all-packages"
  }
}
