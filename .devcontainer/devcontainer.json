{
  "name": "Environmental Health Platform (Workspace)",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.dev.yml"
  ],
  "service": "backend",
  "workspaceFolder": "/workspace",
  "remoteUser": "dev",
  "postCreateCommand": "uv sync --all-packages",
  "forwardPorts": [
    "api:8000",
    "mock:8001",
    "prefect-server:4200",
    "frontend:2718"
  ],
  "portsAttributes": {
    "8000": { "label": "FastAPI Core Analytics Engine", "onAutoForward": "notify" },
    "8001": { "label": "Mock UK Met Office API", "onAutoForward": "notify" },
    "4200": { "label": "Prefect Dashboard UI", "onAutoForward": "notify" },
    "2718": { "label": "Marimo Interactive Dashboard", "onAutoForward": "notify" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "marimo-team.marimo-vscode",
        "astral-sh.ty"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",  
        "python.defaultInterpreterPath": "${workspaceFolder}/.devcontainer/.venv/bin/python",
        "python.analysis.extraPaths": [
          "${workspaceFolder}/backend",
          "${workspaceFolder}/api",
          "${workspaceFolder}/frontend",
          "${workspaceFolder}/utils",
          "${workspaceFolder}/mock"
        ],
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [],
        
        "python.languageServer": "None",

        // FORCE RUFF TO ACT AS THE FORMATTER IN THE UI
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        }
      }
    }
  }
}
