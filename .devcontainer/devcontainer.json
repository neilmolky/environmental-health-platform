{
  "name": "Environmental Health Platform (Workspace)",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "./docker-compose.dev.yml"
  ],
  "service": "backend",
  "workspaceFolder": "/workspace",
  "containerEnv": {
    "UV_LINK_MODE": "copy"
  },
  "runServices": [
    "backend",
    "minio",
    "azurite",
    "mock-services"
  ],
  "forwardPorts": [
    "mock-services:8001"
  ],
  
  "portsAttributes": {
    "mock-service:8001": {
      "label": "Mock Services API",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "marimo-team.marimo-vscode",
        "astral-sh.ty"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.analysis.extraPaths": [
          "${workspaceFolder}/backend",
          "${workspaceFolder}/api",
          "${workspaceFolder}/frontend",
          "${workspaceFolder}/utils",
          "${workspaceFolder}/mock-services"
        ],
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [],
        
        "python.languageServer": "None",

        // FORCE RUFF TO ACT AS THE FORMATTER IN THE UI
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        }
      }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "uv sync --frozen --all-packages"
  }
}
